# ===========================================
# Hitokoto API - EdgeOne Pages 环境变量配置
# ===========================================
# 使用方式：
#   1. 复制此文件为 .env
#   2. 在 EdgeOne Pages 控制台 > 项目设置 > 环境变量 中配置
#   3. 或使用 edgeone pages env pull 拉取到本地
#
# 环境变量使用双下划线 __ 作为嵌套分隔符
# 例如：redis__host 对应配置项 redis.host
# ===========================================

# -------- 运行环境 --------
NODE_ENV=production

# -------- Redis 配置（必需） --------
# Redis 用于存储句子数据，是核心依赖
REDIS__HOST=127.0.0.1
REDIS__PORT=6379
REDIS__PASSWORD=
REDIS__DATABASE=0

# -------- 句子库 A/B 切换 --------
# A/B 双库用于无感知更新句子数据
SENTENCES_AB_SWITCHER__A=1
SENTENCES_AB_SWITCHER__B=2

# -------- 远程句子库地址 --------
REMOTE_SENTENCES_URL=https://cdn.jsdelivr.net/gh/hitokoto-osc/sentences-bundle@latest/

# -------- 扩展功能 --------
# 是否启用网易云音乐接口
EXTENSIONS__NETEASE=true

# -------- 服务器配置 --------
SERVER__COMPRESS_BODY=true

# -------- 请求统计 --------
REQUESTS__ENABLED=true

# -------- 遥测（Sentry 错误追踪） --------
TELEMETRY__PERFORMANCE=false
TELEMETRY__ERROR=false
TELEMETRY__USAGE=false
TELEMETRY__DEBUG=false

# -------- MySQL 配置（可选，用于状态统计） --------
DATABASE=mysql
MYSQL__HOST=127.0.0.1
MYSQL__PORT=3306
MYSQL__USERNAME=root
MYSQL__PASSWORD=
MYSQL__DATABASE=hitokoto

# -------- Sentry DSN（可选） --------
# 如果启用了遥测错误报告，需要配置此项
# SENTRY_DSN=https://xxx@sentry.io/xxx